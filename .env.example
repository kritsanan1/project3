# Vite React TypeScript Starter - Environment Configuration Template
# Copy this file to .env and update the values according to your setup

# ==================================
# APPLICATION CONFIGURATION
# ==================================

# Application Name - Used in browser title and meta tags
VITE_APP_NAME=Vite React TypeScript Starter

# Application Version - Automatically updated during build
VITE_APP_VERSION=1.0.0

# Environment Mode - development, staging, production
VITE_NODE_ENV=development

# Base URL for the application (useful for subdirectory deployments)
# Example: https://yoursite.com/app/ would need VITE_BASE_URL=/app/
VITE_BASE_URL=/

# ==================================
# AYRSHARE API CONFIGURATION
# ==================================

# Ayrshare API Key - Get from https://app.ayrshare.com/
VITE_AYRSHARE_API_KEY=your-ayrshare-api-key-here

# Ayrshare API Base URL (default: https://app.ayrshare.com/api)
VITE_AYRSHARE_BASE_URL=https://app.ayrshare.com/api

# Ayrshare Webhook Secret (for webhook verification)
VITE_AYRSHARE_WEBHOOK_SECRET=your-webhook-secret-here

# ==================================
# API CONFIGURATION
# ==================================

# Primary API Base URL - Backend server endpoint
# Development: http://localhost:3000 or http://localhost:8000
# Production: https://api.yourdomain.com
VITE_API_URL=http://localhost:3000

# API Version - For versioned APIs
VITE_API_VERSION=v1

# API Timeout - Request timeout in milliseconds (default: 10000)
VITE_API_TIMEOUT=10000

# GraphQL Endpoint (if using GraphQL)
VITE_GRAPHQL_URL=http://localhost:3000/graphql

# WebSocket URL (for real-time features)
VITE_WEBSOCKET_URL=ws://localhost:3000/ws

# ==================================
# AUTHENTICATION & SECURITY
# ==================================

# JWT Configuration
VITE_JWT_SECRET_KEY=your-super-secret-jwt-key-here
VITE_JWT_EXPIRY=24h

# OAuth Configuration (Social Login)
VITE_GOOGLE_CLIENT_ID=your-google-client-id
VITE_FACEBOOK_APP_ID=your-facebook-app-id
VITE_GITHUB_CLIENT_ID=your-github-client-id

# Auth0 Configuration (if using Auth0)
VITE_AUTH0_DOMAIN=your-domain.auth0.com
VITE_AUTH0_CLIENT_ID=your-auth0-client-id
VITE_AUTH0_AUDIENCE=your-api-identifier

# CSRF Protection
VITE_CSRF_TOKEN_NAME=_csrf_token

# ==================================
# THIRD-PARTY SERVICES
# ==================================

# Analytics
VITE_GOOGLE_ANALYTICS_ID=GA-XXXXX-X
VITE_HOTJAR_ID=your-hotjar-id
VITE_MIXPANEL_TOKEN=your-mixpanel-token

# Error Tracking
VITE_SENTRY_DSN=https://xxx@sentry.io/project-id
VITE_SENTRY_ENVIRONMENT=development

# Payment Processing
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxx
VITE_PAYPAL_CLIENT_ID=your-paypal-client-id

# Cloud Storage
VITE_AWS_S3_BUCKET=your-s3-bucket-name
VITE_AWS_REGION=us-east-1
VITE_AWS_ACCESS_KEY_ID=your-aws-access-key
VITE_CLOUDINARY_CLOUD_NAME=your-cloudinary-name

# Email Services
VITE_EMAILJS_SERVICE_ID=your-emailjs-service-id
VITE_EMAILJS_TEMPLATE_ID=your-emailjs-template-id
VITE_EMAILJS_PUBLIC_KEY=your-emailjs-public-key

# Maps & Location
VITE_GOOGLE_MAPS_API_KEY=your-google-maps-api-key
VITE_MAPBOX_ACCESS_TOKEN=your-mapbox-access-token

# ==================================
# FEATURE FLAGS
# ==================================

# Enable/disable features for different environments
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_ERROR_TRACKING=true
VITE_ENABLE_DEBUG_MODE=true
VITE_ENABLE_SERVICE_WORKER=false

# Feature toggles for new features
VITE_FEATURE_NEW_DASHBOARD=false
VITE_FEATURE_BETA_UI=false
VITE_FEATURE_EXPERIMENTAL_API=false

# ==================================
# DEVELOPMENT CONFIGURATION
# ==================================

# Development server configuration
VITE_DEV_SERVER_PORT=5173
VITE_DEV_SERVER_HOST=localhost

# Mock API (for development without backend)
VITE_USE_MOCK_API=false
VITE_MOCK_API_DELAY=500

# Debug settings
VITE_DEBUG_REDUX=false
VITE_DEBUG_API_CALLS=true
VITE_DEBUG_PERFORMANCE=false

# Hot reload settings
VITE_HMR_OVERLAY=true
VITE_HMR_PORT=24678

# ==================================
# BUILD CONFIGURATION
# ==================================

# Build optimization settings
VITE_BUILD_SOURCEMAP=false
VITE_BUILD_ANALYZE=false
VITE_BUILD_TARGET=es2015

# Asset optimization
VITE_COMPRESS_ASSETS=true
VITE_OPTIMIZE_IMAGES=true

# ==================================
# DATABASE CONFIGURATION (if applicable)
# ==================================

# Database connection (for full-stack apps)
DATABASE_URL=postgresql://user:password@localhost:5432/dbname
DATABASE_POOL_SIZE=10

# Redis (for caching/sessions)
REDIS_URL=redis://localhost:6379

# ==================================
# MONITORING & LOGGING
# ==================================

# Log levels: error, warn, info, debug
VITE_LOG_LEVEL=info

# Performance monitoring
VITE_PERFORMANCE_BUDGET_JS=250
VITE_PERFORMANCE_BUDGET_CSS=100

# ==================================
# SECURITY HEADERS
# ==================================

# Content Security Policy
VITE_CSP_SCRIPT_SRC="'self' 'unsafe-inline'"
VITE_CSP_STYLE_SRC="'self' 'unsafe-inline'"

# ==================================
# MISCELLANEOUS
# ==================================

# Internationalization
VITE_DEFAULT_LANGUAGE=en
VITE_SUPPORTED_LANGUAGES=en,es,fr,de

# Theme configuration
VITE_DEFAULT_THEME=light
VITE_ENABLE_DARK_MODE=true

# Contact information
VITE_SUPPORT_EMAIL=support@yourapp.com
VITE_COMPANY_NAME=Your Company Name

# ==================================
# ENVIRONMENT-SPECIFIC OVERRIDES
# ==================================

# Production overrides (uncomment for production)
# VITE_NODE_ENV=production
# VITE_API_URL=https://api.yourapp.com
# VITE_ENABLE_DEBUG_MODE=false
# VITE_BUILD_SOURCEMAP=false

# Staging overrides (uncomment for staging)
# VITE_NODE_ENV=staging
# VITE_API_URL=https://staging-api.yourapp.com
# VITE_ENABLE_ANALYTICS=true

# ==================================
# NOTES & GUIDELINES
# ==================================

# 1. SECURITY: Never commit actual API keys or secrets to version control
# 2. NAMING: All Vite environment variables must start with VITE_
# 3. TYPES: All environment variables are strings - cast to needed types in code
# 4. DEFAULTS: Provide sensible defaults in your code for optional variables
# 5. VALIDATION: Validate required environment variables at app startup

# Example validation in your app:
# const requiredEnvVars = ['VITE_API_URL'];
# requiredEnvVars.forEach(envVar => {
#   if (!import.meta.env[envVar]) {
#     throw new Error(`Missing required environment variable: ${envVar}`);
#   }
# });

# ==================================
# QUICK SETUP CHECKLIST
# ==================================

# □ Copy .env.example to .env
# □ Update VITE_APP_NAME with your application name
# □ Set VITE_API_URL to your backend server
# □ Configure authentication providers (Google, Auth0, etc.)
# □ Set up analytics and error tracking
# □ Enable relevant feature flags
# □ Test environment variable loading: console.log(import.meta.env)